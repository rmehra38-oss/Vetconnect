{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information for pet owners and doctors",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "doctor", "admin"] },
        "phone": { "type": "string" },
        "mobile": { "type": "string" },
        "qualification": { "type": "string" },
        "experience": { "type": "string" },
        "specialization": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "charges": { "type": "string" },
        "timings": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "videoEnabled": { "type": "boolean" },
        "audioEnabled": { "type": "boolean" },
        "degreeUploaded": { "type": "boolean" },
        "photoUploaded": { "type": "boolean" },
        "registrationStep": { "type": "string", "enum": ["pending", "completed"] },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Pet": {
      "title": "Pet",
      "description": "Pet or livestock profile",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "species": { "type": "string" },
        "breed": { "type": "string" },
        "age": { "type": "number" },
        "vaccinations": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "species", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["pet", "farm"] },
        "subcategory": { "type": "string" },
        "image": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "createdAt"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "Veterinary consultation session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "doctorId": { "type": "string" },
        "petId": { "type": "string" },
        "type": { "type": "string", "enum": ["whatsapp", "audio", "video", "emergency"] },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "cancelled"] },
        "symptoms": { "type": "string" },
        "prescription": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User accounts"
    },
    "/pets/{petId}": {
      "schema": "Pet",
      "description": "Pets and livestock records"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/consultations/{consultationId}": {
      "schema": "Consultation",
      "description": "Consultation records"
    }
  }
}
